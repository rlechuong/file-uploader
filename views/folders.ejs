<%- include("partials/header.ejs") %>

<nav aria-label="Breadcrumb">
  <a href="/folders">Home</a>
  <% folderPath.forEach((crumb, index) => { %>
    &gt;
    <% if (index === folderPath.length - 1) { %>
      <span><%= crumb.name %></span>
    <% } else { %>
      <a href="/folders/<%= crumb.id %>"><%= crumb.name %></a>
    <% } %>
  <% }) %>
</nav>

<% if (allErrors.length > 0) { %>
  <ul class="error-list">
    <% allErrors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<div class="folder-header">
  <h2><%= folder.id ? folder.name : "Root" %></h2>
  <% if (folder.id) { %>
    <div class="folder-actions">
      <button data-action="open-rename" class="btn btn--secondary">Rename Folder</button>
      <button data-action="open-share" class="btn btn--secondary">Share Folder</button>
      <form action="/folders/<%= folder.id %>/delete" method="POST" 
        onsubmit="return confirm('Delete this folder and everything inside of it?')">
        <button type="submit" class="btn btn--danger">Delete Folder</button>
      </form>
    </div>
  <% } %>
</div>

<div class="folder-toolbar">
  <button data-action="open-create" class="btn">New Folder</button>
  <button data-action="open-upload" class="btn">Upload File</button>
</div>

<dialog id="createDialog">
  <form action="<%= folder.id ? `/folders/${folder.id}/folders` : `/folders` %>" method="POST">
    <h3>New Folder</h3>
    <label for="create-name">Folder Name</label>
    <input id="create-name" name="name" type="text" required />

    <div class="dialog-actions">
      <button type="submit" class="btn">Create</button>
      <button type="button" data-action="cancel-create" class="btn btn--secondary">Cancel</button>
    </div>
  </form>
</dialog>

<dialog id="uploadDialog">
  <form action="<%= folder.id ? `/folders/${folder.id}/files` : `/files` %>" method="POST" 
    enctype="multipart/form-data">
    <h3>Upload File</h3>
    <label for="file">Upload File</label>
    <input id="file" name="file" type="file" required />

    <div class="dialog-actions">
      <button type="submit" class="btn">Upload</button>
      <button type="button" data-action="cancel-upload" class="btn btn--secondary">Cancel</button>
    </div>
  </form>
</dialog>

<% if (folder.id) { %>
  <dialog id="renameDialog">
    <form action="/folders/<%= folder.id %>/rename" method="POST">
      <h3>Rename Folder</h3>
      <label for="rename-name">Folder Name</label>
      <input id="rename-name" name="name" type="text" value="<%= folder.name %>" required />

      <div class="dialog-actions">
        <button type="submit" class="btn">Save</button>
        <button type="button" data-action="cancel-rename" class="btn btn--secondary">Cancel</button>
      </div>
    </form>
  </dialog>
<% } %>

<% if (folder.id) { %>
  <dialog id="shareDialog" <% if (shareLink) { %> data-open="true" <% } %>>
    <form action="/folders/<%= folder.id %>/share" method="POST">
      <h3>Share Folder</h3>
      <label for="shareLinkDuration">Link Expires In</label>
      <select id="shareLinkDuration" name="shareLinkDuration">
        <option value="1h">1 Hour</option>
        <option value="1d">1 Day</option>
        <option value="1w">1 Week</option>
      </select>

      <div class="dialog-actions">
        <button type="submit" class="btn">Create Link</button>
        <button type="button" data-action="cancel-share" class="btn btn--secondary">Cancel</button>
      </div>
    </form>

    <% if (shareLink) { %>
      <div class="share-link-result">
        <p>Share This Link</p>
        <div class="share-link-row">
          <input type="text" id="shareLinkUrl" value="/shared/<%= shareLink.token %>" readonly />
          <button type="button" id="copyShareLink" class="btn btn--secondary">Copy Link</button>
        </div>
      </div>
    <% } %>
  </dialog>
<% } %>

<h3>Folders</h3>
<ul class="entry-list">
<% folder.subfolders.forEach(subfolder => { %>
  <li>
    <a href="/folders/<%= subfolder.id %>">📁 <%= subfolder.name %></a>
  </li>
<% }) %>
</ul>

<h3>Files</h3>
<ul class="entry-list">
<% folder.files.forEach(file => { %>
  <li>
    <a href="/files/<%= file.id %>">📄 <%= file.name %></a>
  </li>
<% }) %>
</ul>

<% if (folder.id) { %>
  <a href="<%= folder.parentId ? `/folders/${folder.parentId}` : '/folders' %>" class="link-back">Back</a>
<% } %>

<%- include("partials/footer.ejs") %>
