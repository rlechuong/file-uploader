<%- include("partials/header.ejs") %>

<h2><%= file.name %></h2>

<p>Size: <%= formattedSize %></p>
<p>Type: <%= file.mimeType %></p>
<p>Uploaded: <%= formattedCreatedDate %></p>
<p>Updated: <%= formattedUpdatedDate %></p>

<a href="/files/<%= file.id %>/download">Download</a>

<form action="/files/<%= file.id %>/delete" method="POST"
  onsubmit="return confirm(`Delete this file?`)">
  <button type="submit">Delete File</button>
</form>

<a href="<%= file.folderId ? `/folders/${file.folderId}` : `/folders` %>">Back</a>

<%- include("partials/footer.ejs") %>